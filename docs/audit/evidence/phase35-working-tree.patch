+  if (figureId !== undefined && figureId !== null && String(figureId) !== "") return `id:${String(figureId)}`;
+  if (figureSlug) return `slug:${String(figureSlug)}`;
+  return `source:${String(item.source || "unknown")}:${String(item.sourceId || "unknown")}`;
