{
  "name": "modelwiki-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --external @prisma/client --external bcryptjs --external sharp",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "admin-js-check": "node scripts/admin-js-check.mjs",
    "test": "vitest run --reporter verbose",
    "test:unit": "vitest run --reporter verbose src/test/bigint.test.ts src/test/lifecycle.test.ts src/test/migration-store-mode.test.ts src/test/migration-dual-write.test.ts src/test/migration-dto-parse.test.ts src/test/migration-full.test.ts src/test/review-update-security.test.ts",
    "test:contract": "vitest run --reporter verbose src/test/app-contract.test.ts src/test/admin-contract.test.ts src/test/review-contract.test.ts",
    "test:integration": "vitest run --reporter verbose src/test/integration/",
    "test:db": "vitest run --reporter verbose src/test/integration/",
    "test:migration": "vitest run --reporter verbose src/test/migration-safety.test.ts",
"test:app-startup": "vitest run --reporter verbose src/test/app-startup.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "@types/nodemailer": "^6.4.24",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "nodemailer": "^6.10.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.1.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
