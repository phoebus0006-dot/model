# ModelWiki Production Environment Variables Template
# Copy to .env.production and fill in secure values (never commit real secrets)

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database & Redis Connections
DATABASE_URL=postgresql://modelwiki:change_me_secure_password@postgres:5432/modelwiki?schema=public
REDIS_URL=redis://:change_me_redis_password@redis:6379

# JWT Secrets (Must be distinct, >= 32 characters)
USER_JWT_SECRET=change_me_user_jwt_secret_at_least_32_characters_long!
ADMIN_JWT_SECRET=change_me_admin_jwt_secret_at_least_32_characters_long!
JWT_SECRET=change_me_user_jwt_secret_at_least_32_characters_long!
REVIEW_CACHE_SIGNING_SECRET=change_me_review_cache_signing_secret_32_chars!

# Site URL & External Services
SITE_URL=https://www.phoebusstudio.com
ENABLE_PUBLIC_REGISTRATION=true

# Optional SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
