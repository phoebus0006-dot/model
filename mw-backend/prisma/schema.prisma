generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Figure {
  id                 BigInt     @id @default(autoincrement())
  slug               String     @unique
  name               String
  nameJp             String?    @map("name_jp")
  nameEn             String?    @map("name_en")
  description        String?
  scale              String?
  material           String?
  priceJpy           Int?       @map("price_jpy")
  releaseDate        DateTime?  @map("release_date")
  heightMm           Int?       @map("height_mm")
  weightG            Int?       @map("weight_g")
  janCode            String?    @unique @map("jan_code")
  parentId           BigInt?    @map("parent_id")
  seriesId           BigInt?    @map("series_id")
  manufacturerId     BigInt?    @map("manufacturer_id")
  activeRevisionId   BigInt?    @unique @map("active_revision_id")
  mfcId              String?    @map("mfc_id")
  productLine        String?    @map("product_line")
  hobbySearchId      String?    @map("hobby_search_id")
  ageRating          String?    @map("age_rating")
  amiamiId           String?    @map("amiami_id")
  hljId              String?    @map("hlj_id")
  isDeleted          Boolean    @default(false) @map("is_deleted")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  parent             Figure?            @relation("FigureLineage", fields: [parentId], references: [id])
  children           Figure[]           @relation("FigureLineage")
  series             Series?            @relation(fields: [seriesId], references: [id])
  manufacturer       Manufacturer?      @relation(fields: [manufacturerId], references: [id])
  activeRevision     Revision?          @relation("ActiveRevision", fields: [activeRevisionId], references: [id])
  images             FigureImage[]
  revisions          Revision[]         @relation("FigureRevisions")
  categories         FigureCategory[]
  sculptors          FigureSculptor[]
  characters         FigureCharacter[]
  favorites          Favorite[]
  likes              FigureLike[]
  comments           FigureComment[]
  localized          FigureLocalized[]
  releases           FigureRelease[]
  reviews            ReviewItem[]

  @@map("figures")
}

model FigureLocalized {
  id          BigInt   @id @default(autoincrement())
  figureId    BigInt   @map("figure_id")
  language    String
  title       String?
  origin      String?
  character   String?  @map("character_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  figure Figure @relation(fields: [figureId], references: [id])

  @@unique([figureId, language])
  @@map("figure_localized")
}

model FigureRelease {
  id          BigInt    @id @default(autoincrement())
  figureId    BigInt    @map("figure_id")
  edition     String
  releaseDate DateTime? @map("release_date")
  priceJpy    Int?      @map("price_jpy")
  isRerelease Boolean   @default(false) @map("is_rerelease")
  createdAt   DateTime  @default(now()) @map("created_at")

  figure Figure @relation(fields: [figureId], references: [id])

  @@map("figure_releases")
}

model Series {
  id          BigInt   @id @default(autoincrement())
  slug        String   @unique
  name        String
  nameJp      String?  @map("name_jp")
  nameEn      String?  @map("name_en")
  mediaType   String?  @map("media_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  figures        Figure[]
  characters     Character[]

  @@map("series")
}

model Character {
  id          BigInt   @id @default(autoincrement())
  slug        String   @unique
  name        String
  nameJp      String?  @map("name_jp")
  nameEn      String?  @map("name_en")
  seriesId    BigInt?  @map("series_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  series        Series?         @relation(fields: [seriesId], references: [id])
  figures       FigureCharacter[]

  @@map("characters")
}

model Manufacturer {
  id          BigInt   @id @default(autoincrement())
  slug        String   @unique
  name        String
  nameJp      String?  @map("name_jp")
  nameEn      String?  @map("name_en")
  country     String?
  website     String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  figures        Figure[]

  @@map("manufacturers")
}

model Sculptor {
  id          BigInt   @id @default(autoincrement())
  slug        String   @unique
  name        String
  nameJp      String?  @map("name_jp")
  nameEn      String?  @map("name_en")
  alias       String[]
  styleTags   String[] @map("style_tags")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  figures        FigureSculptor[]

  @@map("sculptors")
}

model Category {
  id        BigInt    @id @default(autoincrement())
  slug      String    @unique
  name      String
  parentId  BigInt?   @map("parent_id")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  figures     FigureCategory[]

  @@map("categories")
}

model Revision {
  id              BigInt   @id @default(autoincrement())
  figureId        BigInt   @map("figure_id")
  contentMd       String   @map("content_md")
  summaryMd       String?  @map("summary_md")
  keyPoints       String[] @map("key_points")
  relatedKeywords String[] @map("related_keywords")
  versionNumber   Int      @map("version_number")
  editSummary     String?  @map("edit_summary")
  editorId        BigInt?  @map("editor_id")
  isActive        Boolean  @default(false) @map("is_active")
  promptVersion   String?  @map("prompt_version")
  qualityScore    Decimal? @map("quality_score")
  createdAt       DateTime @default(now()) @map("created_at")

  figure                Figure  @relation("FigureRevisions", fields: [figureId], references: [id])
  activeRevisionFigure  Figure? @relation("ActiveRevision")

  @@unique([figureId, versionNumber])
  @@map("revisions")
}

model FigureImage {
  id        BigInt   @id @default(autoincrement())
  figureId  BigInt   @map("figure_id")
  url       String?  // Legacy: external URL, kept for backward compat
  janCode   String?  @map("jan_code")
  sha256    String?
  size      String   @default("raw")
  format    String    @default("webp")
  width     Int?
  height    Int?
  alt       String?
  blurhash  String?
  fileSize  Int?     @map("file_size")
  sortOrder Int      @default(0) @map("sort_order")
  source    String?
  isNsfw    Boolean  @default(false) @map("is_nsfw")
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  figure Figure @relation(fields: [figureId], references: [id])

  @@unique([figureId, sha256, size], name: "figure_images_figure_sha256_size_key")
  @@map("figure_images")
}

model FigureCategory {
  figureId   BigInt   @map("figure_id")
  categoryId BigInt   @map("category_id")

  figure    Figure   @relation(fields: [figureId], references: [id])
  category  Category @relation(fields: [categoryId], references: [id])

  @@id([figureId, categoryId])
  @@map("figure_category")
}

model FigureSculptor {
  figureId   BigInt  @map("figure_id")
  sculptorId BigInt  @map("sculptor_id")
  role       String?
  isPrimary  Boolean @default(false) @map("is_primary")

  figure    Figure   @relation(fields: [figureId], references: [id])
  sculptor  Sculptor @relation(fields: [sculptorId], references: [id])

  @@id([figureId, sculptorId])
  @@map("figure_sculptor")
}

model FigureCharacter {
  figureId    BigInt  @map("figure_id")
  characterId BigInt  @map("character_id")
  isFeatured  Boolean @default(false) @map("is_featured")

  figure    Figure    @relation(fields: [figureId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@id([figureId, characterId])
  @@map("figure_character")
}

// ─── Frontend User (email-based auth, see AUTH_ACCOUNT_CONTRACT.md §2) ──────
// email/normalizedEmail are nullable in this transitional migration because
// existing users created before this migration may not have email addresses.
// Per contract §7, a future migration will make them NOT NULL after data
// cleanup. normalizedEmail uniqueness is enforced by DB constraint.

model User {
  id                     BigInt    @id @default(autoincrement())
  email                  String?   @unique
  normalizedEmail        String?   @unique @map("normalized_email")
  emailVerifiedAt        DateTime? @map("email_verified_at")
  emailVerifyTokenHash   String?   @map("email_verify_token_hash")
  emailVerifyExpiresAt   DateTime? @map("email_verify_expires_at")
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  passwordHash           String?   @map("password_hash")
  sessionVersion         Int       @default(0) @map("session_version")
  displayName            String    @map("display_name")
  avatarUrl              String?   @map("avatar_url")
  googleSub              String?   @unique @map("google_sub")
  wechatOpenid           String?   @unique @map("wechat_openid")
  role                   String    @default("user")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  favorites      Favorite[]
  favoriteGroups FavoriteGroup[]
  likes          FigureLike[]
  comments       FigureComment[]

  @@map("users")
}

model FavoriteGroup {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id])
  favorites Favorite[]

  @@map("favorite_groups")
}

model Favorite {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  figureId  BigInt   @map("figure_id")
  groupId   BigInt?  @map("group_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user  User           @relation(fields: [userId], references: [id])
  figure Figure         @relation(fields: [figureId], references: [id])
  group FavoriteGroup?  @relation(fields: [groupId], references: [id])

  @@unique([userId, figureId])
  @@map("favorites")
}

model FigureLike {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  figureId  BigInt   @map("figure_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  figure Figure @relation(fields: [figureId], references: [id])

  @@unique([userId, figureId])
  @@map("figure_likes")
}

model FigureComment {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  figureId  BigInt   @map("figure_id")
  body      String
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id])
  figure Figure @relation(fields: [figureId], references: [id])

  @@map("figure_comments")
}

model EntityMapping {
  id         BigInt   @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   BigInt   @map("entity_id")
  source     String
  sourceId   String   @map("source_id")
  sourceName String?  @map("source_name")
  confidence Decimal?
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, source, sourceId])
  @@map("entity_mapping")
}

model RedirectMap {
  id         BigInt   @id @default(autoincrement())
  fromPath   String   @unique @map("from_path")
  toPath     String   @map("to_path")
  statusCode Int      @default(301) @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("redirect_map")
}

// ─── Guanli AdminAccount (username-based auth, see AUTH_ACCOUNT_CONTRACT.md §3) ──

model AdminAccount {
  id                 BigInt    @id @default(autoincrement())
  username           String    @unique
  normalizedUsername String    @unique @map("normalized_username")
  passwordHash       String    @map("password_hash")
  displayName        String    @map("display_name")
  role               String    // "admin" | "reviewer" | "operator"
  isActive           Boolean   @default(true) @map("is_active")
  sessionVersion     Int       @default(0) @map("session_version")
  lastLoginAt        DateTime? @map("last_login_at")
  passwordChangedAt  DateTime  @default(now()) @map("password_changed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  auditLogs       AdminAuditLog[]
  reviewItems     ReviewItem[]
  reviewDecisions ReviewDecision[]

  @@map("admin_accounts")
}

model AdminAuditLog {
  id           BigInt   @id @default(autoincrement())
  actorAdminId BigInt   @map("actor_admin_id")
  action       String   // "login" | "logout" | "create_admin" | "disable_admin" | "change_password" | ...
  targetType   String   @map("target_type")  // "admin" | "review" | "figure" | ...
  targetId     String?  @map("target_id")
  requestId    String?  @map("request_id")
  ip           String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  admin AdminAccount @relation(fields: [actorAdminId], references: [id])

  @@index([actorAdminId, createdAt])
  @@map("admin_audit_logs")
}

// ─── Phase 1+2 Review Workflow (see docs/implementation/PHASE12_CONTRACT.md) ───
// PostgreSQL is the source of truth; Redis mirrors as cache/index only.
// reviewerId references AdminAccount (not User) per AUTH_ACCOUNT_CONTRACT.md §3.

model ReviewItem {
  id                   String    @id
  type                 String
  riskType             String?   @map("risk_type")
  status               String    @default("pending")
  title                String
  source               String?
  sourceId             String?   @map("source_id")
  figureId             BigInt?   @map("figure_id")
  figureSlug           String?   @map("figure_slug")
  priority             Int       @default(1)
  confidence           Float?
  riskReason           String?   @db.VarChar(1000)
  candidateImage       Json?
  candidateAsset       Json?     @map("candidate_asset")
  currentPublicImage   Json?     @map("current_public_image")
  originalEvidence     Json?     @map("original_evidence")
  currentStateSnapshot Json?     @map("current_state_snapshot")
  detailSnapshot       Json?     @map("detail_snapshot")
  suggestedAction      String?   @map("suggested_action")
  payload              Json?
  notes                String?
  evidenceFingerprint  String    @map("evidence_fingerprint")
  forceReopen          Boolean   @default(false) @map("force_reopen")
  crawlerJobId         String?   @map("crawler_job_id")
  automation           Json?
  reviewerId           BigInt?   @map("reviewer_id")
  decisionReason       String?   @db.VarChar(2000) @map("decision_reason")
  decisionAt           DateTime? @map("decision_at")
  lastAction           String?   @map("last_action")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  figure     Figure?          @relation(fields: [figureId], references: [id])
  reviewer   AdminAccount?    @relation(fields: [reviewerId], references: [id])
  crawlerJob CrawlerJob?      @relation(fields: [crawlerJobId], references: [id])
  decisions  ReviewDecision[]

  @@index([status, createdAt])
  @@index([figureId, riskType, status])
  @@index([figureId, riskType, evidenceFingerprint])
  @@index([evidenceFingerprint])
  @@map("review_items")
}

model ReviewDecision {
  id                 BigInt   @id @default(autoincrement())
  reviewItemId       String   @map("review_item_id")
  action             String
  previousStatus     String   @map("status_before")
  nextStatus         String   @map("status_after")
  reviewerId         BigInt?  @map("reviewer_id")
  reviewerRole       String   @map("reviewer_role")
  decisionReason     String?  @db.VarChar(2000) @map("decision_reason")
  crawlerJobId       String?  @map("crawler_job_id")
  candidateImageHash String?  @map("candidate_image_hash")
  evidenceFingerprint String  @map("evidence_fingerprint")
  requestId          String?  @map("request_id")
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")

  reviewItem ReviewItem    @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)
  reviewer   AdminAccount? @relation(fields: [reviewerId], references: [id])
  crawlerJob CrawlerJob?   @relation(fields: [crawlerJobId], references: [id])

  @@index([reviewItemId, createdAt])
  @@index([evidenceFingerprint])
  @@index([requestId])
  @@map("review_decisions")
}

model CrawlerJob {
  id              String    @id
  source          String
  task            String
  runner          String    @default("server_safe")
  status          String    @default("created")
  priority        Int       @default(1)
  payload         Json?
  result          Json?
  resultSummary   Json?     @map("result_summary")
  error           String?
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3) @map("max_attempts")
  notBefore       DateTime? @map("not_before")
  workerId        String?   @map("worker_id")
  linkedReviewItemId String? @map("linked_review_item_id")
  notes           String?
  automation      Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  claimedAt       DateTime? @map("claimed_at")
  runningAt       DateTime? @map("running_at")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reviewItems ReviewItem[]
  decisions   ReviewDecision[]
  events      CrawlerJobEvent[]

  @@index([status, priority, createdAt])
  @@index([source, task])
  @@map("crawler_jobs")
}

// ─── CrawlerJobEvent: append-only state transition history ──────────────────
// One row per CrawlerJob status transition. Provides a full audit trail of
// every status change (created→queued→claimed→running→completed, etc.).

model CrawlerJobEvent {
  id              BigInt   @id @default(autoincrement())
  crawlerJobId    String   @map("crawler_job_id")
  previousStatus  String   @map("previous_status")
  nextStatus      String   @map("next_status")
  agentId         String?  @map("agent_id")
  attempt         Int      @default(0)
  timestamp       DateTime @default(now())
  resultSummary   Json?    @map("result_summary")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")

  crawlerJob CrawlerJob @relation(fields: [crawlerJobId], references: [id], onDelete: Cascade)

  @@index([crawlerJobId, createdAt])
  @@index([crawlerJobId, timestamp])
  @@map("crawler_job_events")
}
